# Server Configuration
NODE_ENV=production
HOST=0.0.0.0
PORT=3000

# Clustering
USE_CLUSTER=true

# Logging
LOG_LEVEL=error

# Features (passive defaults - enabled unless disabled)
USE_WORLDSTATE=true
FEATURES=SOCKET
DISABLE_PRICECHECKS=false

# Cache Hydration
BUILD=

# External APIs (optional)
WFINFO_FILTERED_ITEMS=
WFINFO_PRICES=

# Twitter (optional)
TWITTER_KEY=
TWITTER_SECRET=
TWITTER_BEARER_TOKEN=

# Monitoring (optional)
SENTRY_DSN=
