{
  "name": "warframe-status",
  "version": "2.6.44",
  "private": true,
  "repository": "https://github.com/wfcd/warframe-status.git",
  "license": "Apache-2.0",
  "author": "tobitenno",
  "type": "module",
  "scripts": {
    "build": "npm run generate:routes && nest build",
    "dev": "npm run generate:routes && dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- tsx watch src/main.ts",
    "generate:routes": "tsx scripts/generate-field-routes.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "husky",
    "start": "npm run generate:routes && dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- tsx src/main.ts",
    "start:node": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- node -r tsconfig-paths/register dist/main.js",
    "test": "dotenvx run -f .env.local -f .env -f .env.test --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost mocha --config .mocharc.yaml",
    "test:all": "npm run test && npm run test:integration",
    "test:integration": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost mocha --config .mocharc.integration.yaml",
    "test:watch": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost mocha --config .mocharc.yaml --watch",
    "update:spec": "curl --url https://docs.warframestat.us/openapi.json -G -o src/api-spec/openapi.json --silent"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.60.0",
    "@nestjs/common": "^11.1.18",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.18",
    "@nestjs/platform-express": "^11.1.18",
    "@nestjs/platform-ws": "^11.1.18",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.18",
    "@wfcd/arsenal-parser": "^2.1.2",
    "@wfcd/items": "^1.1273.9",
    "@wfcd/profile-parser": "^2.0.12",
    "cache-manager": "^6.4.3",
    "colors": "1.4.0",
    "express": "^5.2.1",
    "flat-cache": "^6.1.22",
    "json5": "^2.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "warframe-nexus-query": "^2.2.3",
    "warframe-worldstate-data": "^3.11.3",
    "warframe-worldstate-parser": "^5.3.1",
    "winston": "^3.19.0",
    "worldstate-emitter": "^2.4.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nestjs/cli": "^11.0.17",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^11.1.18",
    "@sentry/types": "^10.32.1",
    "@types/chai": "^5.2.3",
    "@types/chai-http": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/flat-cache": "^2.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/twitter": "^1.7.4",
    "@types/ws": "^8.18.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-http": "^5.1.2",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-json-schema": "^0.67.1"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
