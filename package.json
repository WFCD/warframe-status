{
  "name": "warframe-status",
  "version": "1.13.23",
  "author": "tobitenno",
  "repository": "https://github.com/wfcd/warframe-status.git",
  "private": true,
  "dependencies": {
    "@sentry/node": "^7.107.0",
    "@sentry/tracing": "^7.107.0",
    "@wfcd/arsenal-parser": "^2.0.1",
    "apicache": "^1.6.3",
    "colors": "1.4.0",
    "cors": "^2.8.5",
    "cron": "^3.1.6",
    "dotenv": "^16.4.5",
    "express": "^4.19.1",
    "express-async-handler": "^1.2.0",
    "express-favicon-short-circuit": "^1.1.1",
    "flat-cache": "3.0.4",
    "helmet": "^7.1.0",
    "ip-address": "^9.0.5",
    "json-fetch-cache": "^1.2.6",
    "node-fetch": "^2.7.0",
    "swagger-stats": "^0.99.7",
    "warframe-items": "^1.1262.10",
    "warframe-nexus-query": "^2.0.2",
    "warframe-worldstate-data": "^2.3.9",
    "warframe-worldstate-parser": "^3.0.3",
    "winston": "^3.12.0",
    "worldstate-emitter": "^2.1.1",
    "ws": "^7.5.9"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8",
    "prom-client": "^11.5.3",
    "utf-8-validate": "^5.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.2.1",
    "@commitlint/config-conventional": "^19.1.0",
    "@sentry/types": "^7.107.0",
    "@types/apicache": "^1.6.6",
    "@types/cors": "^2.8.17",
    "@types/cron": "^2.4.0",
    "@types/express": "^4.17.21",
    "@types/flat-cache": "^2.0.0",
    "@types/helmet": "4.0.0",
    "@types/twitter": "^1.7.4",
    "@types/ws": "^8.5.3",
    "@wfcd/eslint-config": "latest",
    "c8": "^9.1.0",
    "chai": "^4.4.1",
    "chai-http": "^4.4.0",
    "cross-env": "^7.0.3",
    "husky": "^9.0.11",
    "install-peerdeps": "^3.0.3",
    "lint-staged": "^15.2.2",
    "mocha": "^10.3.0",
    "nodemon": "^3.1.0"
  },
  "scripts": {
    "start": "node main.js",
    "dev": "nodemon",
    "dev:pm2": "pm2 start warframe-status.json",
    "lint": "eslint src/ --ext .js,.mjs",
    "lint:fix": "eslint src/ --fix --ext .js,.mjs",
    "test": "cross-env HOSTNAME=localhost c8 mocha",
    "update:spec": "curl --url https://docs.warframestat.us/openapi.json -G -o src/api-spec/openapi.json --silent",
    "hydrate:cache": "BUILD=build WFINFO_FILTERED_ITEMS=$WFINFO_FILTERED_ITEMS WFINFO_PRICES=$WFINFO_PRICES node ./src/lib/hydrate.js",
    "coverage": "npm test && c8 report --reporter=text-lcov | coveralls",
    "build": "npm run hydrate:cache",
    "postinstall": "if [ \"$NODE_ENV\" = \"dev\" ] ; then npx -p install-peerdeps@latest install-peerdeps @wfcd/eslint-config@latest -S ; fi",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18.0.0 < 19",
    "npm": ">=10.0.0 < 11"
  },
  "license": "Apache-2.0",
  "prettier": "@wfcd/eslint-config/prettier",
  "type": "module"
}
