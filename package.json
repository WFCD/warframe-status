{
  "name": "warframe-status",
  "version": "3.2.3",
  "private": true,
  "repository": "https://github.com/wfcd/warframe-status.git",
  "license": "Apache-2.0",
  "author": "tobitenno",
  "type": "module",
  "scripts": {
    "build": "npm run generate:dtos && npm run generate:routes && nest build",
    "dev": "npm run generate:dtos && npm run generate:routes && dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- tsx watch src/main.ts",
    "docs:build": "npm run docs:lint && npm run docs:bundle",
    "docs:bundle": "redocly bundle --config .redocly.yaml docs/openapi/openapi.json -o docs/web/openapi --ext yaml && redocly bundle --config .redocly.yaml docs/openapi/openapi.json -o docs/web/openapi --ext json",
    "docs:export": "dotenvx run -f .env.test --ignore=MISSING_ENV_FILE -- tsx scripts/export-openapi.ts",
    "docs:lint": "npm run docs:export && redocly lint --config .redocly.yaml docs/openapi/openapi.json",
    "docs:preview": "npm run docs:build && redocly preview -d docs/web",
    "docs:serve": "npm run docs:build && npx serve -s docs/web",
    "generate:dtos": "tsx scripts/generate-worldstate-dtos.ts",
    "generate:routes": "tsx scripts/generate-field-routes.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "prepare": "npm run generate:dtos && npm run generate:routes && husky",
    "start": "npm run generate:dtos && npm run generate:routes && dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- tsx src/main.ts",
    "start:node": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- node --import tsx dist/main.js",
    "test": "dotenvx run -f .env.local -f .env -f .env.test --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost c8 mocha --config .mocharc.yaml",
    "test:all": "npm run test && npm run test:integration",
    "test:integration": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost mocha --config .mocharc.integration.yaml",
    "test:watch": "dotenvx run -f .env.local -f .env --ignore=MISSING_ENV_FILE -- cross-env HOST=localhost mocha --config .mocharc.yaml --watch"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.71.3",
    "@nestjs/common": "^11.1.26",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-ws": "^11.1.24",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/websockets": "^11.1.24",
    "@wfcd/arsenal-parser": "^2.1.2",
    "@wfcd/items": "^1.1274.63",
    "@wfcd/profile-parser": "^2.0.12",
    "cache-manager": "^7.2.8",
    "colors": "1.4.0",
    "express": "^5.2.1",
    "flat-cache": "^6.1.22",
    "json5": "^2.2.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.22.4",
    "warframe-nexus-query": "^2.3.0",
    "warframe-worldstate-data": "^3.16.1",
    "warframe-worldstate-parser": "^5.3.13",
    "winston": "^3.19.0",
    "worldstate-emitter": "^2.5.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.24",
    "@redocly/cli": "^2.34.0",
    "@sentry/types": "^10.55.0",
    "@types/chai": "^5.2.3",
    "@types/chai-http": "^4.2.4",
    "@types/express": "^5.0.6",
    "@types/flat-cache": "^2.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.13.2",
    "@types/twitter": "^1.7.4",
    "@types/ws": "^8.18.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chai-http": "^5.1.2",
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "mocha": "^11.7.6",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3",
    "typescript-json-schema": "^0.67.4",
    "utf-8-validate": "^5.0.10"
  },
  "optionalDependencies": {
    "bufferutil": "^4.1.0",
    "utf-8-validate": "^6.0.6"
  }
}
